// 主色调
$syp-primary = #4080FF
$syp-primary-light = #6699FF
$syp-primary-dark = #3366CC

// 中性色
$syp-bg-primary = #FFFFFF
$syp-bg-secondary = #F5F5F5
$syp-bg-tertiary = #EEEEEE

// 文字颜色
$syp-text-primary = #1F2329
$syp-text-secondary = #646A73
$syp-text-tertiary = #8F959E
$syp-text-disabled = #BBBFC4

// 边框颜色
$syp-border-primary = #DEE0E3
$syp-border-secondary = #EBEBEB

// 状态色
$syp-success = #34C724
$syp-warning = #FF8800
$syp-error = #F54A45

// 状态背景色（浅色模式）
$syp-status-info-bg = #f7fbff
$syp-status-info-border = #d6e4f5
$syp-status-success-bg = #f3fbf5
$syp-status-success-border = #d7f0df
$syp-status-error-bg = #fff5f5
$syp-status-error-border = #f2d6d6
$syp-status-error-deep-bg = #fff1f1
$syp-status-warning-bg = #fffbf0
$syp-status-warning-border = #f5e6c8
$syp-status-warning-deep-bg = #fff8e6

// Chip / 标签
$syp-chip-bg = #f3f6fa
$syp-chip-text = #6a7788

// 强调色
$syp-accent = #355d90
$syp-accent-hover-bg = rgba(53, 93, 144, 0.08)

// 操作色
$syp-action-primary = #2f6dd5
$syp-action-primary-hover = #2b62c0
$syp-action-danger = #d92d20
$syp-action-danger-hover = #c6281d

// 图标区域
$syp-icon-bg = #f2f5fa
$syp-icon-color = #355d90

// 状态徽章
$syp-badge-ready-bg = rgba(52, 199, 36, 0.12)
$syp-badge-ready-text = #2f8b24
$syp-badge-disabled-bg = rgba(245, 74, 69, 0.12)
$syp-badge-disabled-text = #b33d39

// 渐变卡片背景
$syp-card-bg-gradient = linear-gradient(180deg, #ffffff 0%, #f8fafc 100%)

// 间距系统（基于 8px）
$syp-spacing-xs = 4px
$syp-spacing-sm = 8px
$syp-spacing-md = 16px
$syp-spacing-lg = 24px
$syp-spacing-xl = 32px

// 圆角
$syp-radius-sm = 4px
$syp-radius-md = 8px
$syp-radius-lg = 12px
$syp-radius-xl = 16px

// 阴影
$syp-shadow-sm = 0 1px 2px rgba(0, 0, 0, 0.05)
$syp-shadow-md = 0 4px 12px rgba(0, 0, 0, 0.1)
$syp-shadow-lg = 0 8px 24px rgba(0, 0, 0, 0.15)
$syp-shadow-card-hover = 0 2px 8px rgba(15, 23, 42, 0.04)

// 字体
$syp-font-family = -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif
$syp-font-size-xs = 12px
$syp-font-size-sm = 14px
$syp-font-size-md = 16px
$syp-font-size-lg = 18px
$syp-font-size-xl = 20px

// antd sm 紧凑尺寸
$syp-sm-btn-height = 24px
$syp-sm-btn-padding-y = 0
$syp-sm-btn-padding-x = 8px
$syp-sm-btn-font-size = 12px
$syp-sm-toggle-width = 36px
$syp-sm-toggle-height = 20px
$syp-sm-toggle-dot = 14px
$syp-sm-toggle-translate = 16px
$syp-sm-icon-size = 32px
$syp-sm-icon-radius = 8px
$syp-sm-icon-inner = 18px
$syp-sm-card-padding = 12px
$syp-sm-card-radius = 10px
$syp-sm-input-padding-y = 4px
$syp-sm-input-padding-x = 8px
$syp-sm-row-padding = 10px
$syp-sm-title-size = 22px
$syp-sm-name-size = 14px
$syp-sm-badge-padding = 1px 6px
$syp-sm-badge-font = 11px
