@import "./variables.styl"

.syp-v2
  font-family $syp-font-family
  font-size $syp-font-size-sm
  color $syp-text-primary
  line-height 1.5
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  min-width 0
  max-height calc(100vh - 180px)

  *, *::before, *::after
    box-sizing border-box

  .syp-btn
    display inline-flex
    align-items center
    justify-content center
    height $syp-sm-btn-height
    padding $syp-sm-btn-padding-y $syp-sm-btn-padding-x
    border none
    border-radius $syp-radius-sm
    font-size $syp-sm-btn-font-size
    font-weight 500
    cursor pointer
    transition all 0.2s ease
    outline none

    &:hover
      opacity 0.9

    &:active
      opacity 0.8

    &.syp-btn-primary
      background-color $syp-primary
      color white

    &.syp-btn-secondary
      background-color $syp-bg-secondary
      color $syp-text-primary

    &.syp-btn-text
      background-color transparent
      color $syp-text-secondary

      &:hover
        background-color $syp-bg-secondary

  .syp-card
    background-color $syp-bg-primary
    border-radius $syp-radius-lg
    box-shadow $syp-shadow-sm
    border 1px solid $syp-border-secondary
    padding $syp-spacing-md
    transition box-shadow 0.2s ease

    &:hover
      box-shadow $syp-shadow-md

  .syp-input
    width 100%
    padding $syp-sm-input-padding-y $syp-sm-input-padding-x
    border 1px solid $syp-border-primary
    border-radius $syp-radius-sm
    font-size $syp-sm-btn-font-size
    color $syp-text-primary
    background-color $syp-bg-primary
    line-height 1.5
    transition border-color 0.2s ease

    &:focus
      outline none
      border-color $syp-primary

    &::placeholder
      color $syp-text-tertiary

  .syp-toggle
    position relative
    display inline-block
    width $syp-sm-toggle-width
    height $syp-sm-toggle-height

    input
      opacity 0
      width 0
      height 0

      &:checked + .syp-toggle-slider
        background-color $syp-primary

      &:checked + .syp-toggle-slider:before
        transform translateX($syp-sm-toggle-translate)

    .syp-toggle-slider
      position absolute
      cursor pointer
      top 0
      left 0
      right 0
      bottom 0
      background-color $syp-border-primary
      border-radius $syp-sm-toggle-height
      transition 0.3s

      &:before
        position absolute
        content ""
        height $syp-sm-toggle-dot
        width $syp-sm-toggle-dot
        left 3px
        bottom 3px
        background-color white
        border-radius 50%
        transition 0.3s

  .syp-panel
    display flex
    flex-direction column
    height 100%
    background linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 253, 0.98) 100%)
    border-radius $syp-radius-xl
    box-shadow $syp-shadow-lg
    border 1px solid rgba(222, 224, 227, 0.9)
    overflow hidden

  .syp-header
    display flex
    align-items center
    justify-content space-between
    padding $syp-spacing-md $syp-spacing-lg
    border-bottom 1px solid $syp-border-secondary
    flex-shrink 0

    .syp-header-title
      font-size $syp-font-size-lg
      font-weight 600
      color $syp-text-primary

  .syp-content
    padding $syp-spacing-lg
    overflow-y auto

  .syp-list
    list-style none
    margin 0
    padding 0

    .syp-list-item
      display flex
      align-items center
      padding $syp-spacing-md
      border-bottom 1px solid $syp-border-secondary
      cursor pointer
      transition background-color 0.2s ease

      &:hover
        background-color $syp-bg-secondary

      &:last-child
        border-bottom none

  .syp-empty
    display flex
    flex-direction column
    align-items center
    justify-content center
    padding $syp-spacing-xl
    color $syp-text-tertiary
    text-align center

    .syp-empty-icon
      font-size 48px
      margin-bottom $syp-spacing-md

    .syp-empty-text
      font-size $syp-font-size-md
      margin-bottom $syp-spacing-sm

    .syp-empty-subtext
      font-size $syp-font-size-sm

  .syp-shell
    display grid
    gap 0
    min-height 0
    flex 1

    &.is-quick-publish
      grid-template-columns minmax(0, 1fr)

    &.is-settings
      grid-template-columns 140px minmax(0, 1fr)

  .syp-shell__nav
    padding 12px
    background linear-gradient(180deg, #f7f9fc 0%, #eef2f6 100%)
    border-right 1px solid $syp-border-secondary
    overflow-y auto
    min-height 0

  .syp-shell__section-title
    margin-bottom 8px
    font-size $syp-font-size-xs
    color $syp-text-tertiary
    letter-spacing 0.08em
    text-transform uppercase

  .syp-shell__nav-item
    width 100%
    text-align left
    border none
    background transparent
    color $syp-text-secondary
    padding 6px 10px
    border-radius $syp-radius-sm
    font-size 13px
    margin-bottom 4px
    cursor pointer
    transition all 0.2s ease

    &:hover
      background rgba(64, 128, 255, 0.08)
      color $syp-text-primary

    &.is-active
      background white
      color $syp-text-primary
      box-shadow $syp-shadow-sm

  .syp-shell__main
    display flex
    flex-direction column
    padding $syp-spacing-xl
    background $syp-bg-primary
    min-width 0
    min-height 0
    overflow-y auto
    overflow-x hidden

  .syp-settings-page
    display flex
    flex-direction column
    gap 18px

  .syp-settings-page__header
    display flex
    justify-content space-between
    align-items flex-start
    gap $syp-spacing-md
    flex-shrink 0

  .syp-settings-page__eyebrow
    font-size $syp-font-size-xs
    color $syp-text-tertiary
    letter-spacing 0.08em
    text-transform uppercase

  .syp-settings-page__title
    margin 0
    font-size $syp-sm-title-size
    line-height 1.3
    color $syp-text-primary

  .syp-settings-page__desc
    margin 8px 0 0
    max-width 640px
    font-size $syp-font-size-sm
    color $syp-text-secondary

  .syp-settings-empty
    display flex
    flex-direction column
    gap $syp-spacing-sm
    padding $syp-spacing-lg
    border 1px solid $syp-border-secondary
    border-radius $syp-radius-lg
    background linear-gradient(180deg, #ffffff 0%, #f8fafc 100%)

  .syp-settings-empty__title
    font-size $syp-font-size-lg
    font-weight 600
    color $syp-text-primary

  .syp-settings-empty__desc
    font-size $syp-font-size-sm
    color $syp-text-secondary

  .syp-settings-group-list
    display flex
    flex-direction column
    gap $syp-spacing-md

  .syp-settings-group
    padding $syp-sm-card-padding
    border 1px solid $syp-border-secondary
    border-radius $syp-sm-card-radius
    background linear-gradient(180deg, #ffffff 0%, #f8fafc 100%)

  .syp-settings-group__title
    font-size 13px
    color $syp-text-tertiary

  .syp-settings-group__desc
    margin-top 8px
    font-size $syp-font-size-sm
    color $syp-text-secondary

  .syp-settings-form-list
    display flex
    flex-direction column
    gap 0
    margin-top $syp-spacing-md

  .syp-settings-form-row
    display flex
    align-items center
    justify-content space-between
    gap $syp-spacing-md
    padding $syp-sm-row-padding 0
    border-bottom 1px solid $syp-border-secondary

    &:first-child
      padding-top 0

    &:last-child
      padding-bottom 0
      border-bottom none

  .syp-settings-form-main
    min-width 0
    flex 1

  .syp-settings-form-label
    font-size $syp-font-size-sm
    font-weight 600
    color $syp-text-primary

  .syp-settings-form-desc
    margin-top 4px
    font-size 13px
    color $syp-text-secondary

  .syp-settings-form-control
    display flex
    align-items center
    justify-content flex-end
    gap $syp-spacing-sm
    flex-shrink 0

  .syp-settings-status-text
    font-size $syp-font-size-xs
    color $syp-text-tertiary

  .syp-settings-detail-grid
    display grid
    grid-template-columns repeat(2, minmax(0, 1fr))
    gap $syp-spacing-md

  .syp-settings-detail-card
    padding $syp-sm-card-padding
    border-radius $syp-sm-card-radius
    background linear-gradient(180deg, #ffffff 0%, #f7f9fc 100%)
    border 1px solid $syp-border-secondary

  .syp-settings-detail-card__title
    margin-bottom 14px
    font-size 13px
    color $syp-text-tertiary

  .syp-settings-detail-list
    display flex
    flex-direction column
    gap 12px

  .syp-settings-detail-row
    display grid
    grid-template-columns 72px minmax(0, 1fr)
    gap 12px
    align-items start

  .syp-settings-detail-label
    font-size $syp-font-size-xs
    color $syp-text-tertiary

  .syp-settings-detail-value
    font-size $syp-font-size-sm
    color #475467
    word-break break-all

  @media (max-width: 960px)
    .syp-v2
      height auto
      max-height calc(100vh - 96px)

    .syp-shell
      &.is-quick-publish
        grid-template-columns 1fr

      &.is-settings
        grid-template-columns 1fr

    .syp-shell__nav
      border none
      padding $syp-spacing-md

    .syp-shell__main
      padding $syp-spacing-lg

    .syp-settings-page__title
      font-size 18px

    .syp-settings-form-row
      align-items flex-start
      flex-direction column

    .syp-settings-form-control
      width 100%
      justify-content flex-start

    .syp-settings-detail-grid
      grid-template-columns 1fr
