@import "./variables.styl"

.syp-v2
  font-family $syp-font-family
  font-size $syp-font-size-sm
  color $syp-text-primary
  line-height 1.5
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  min-width 0

  *, *::before, *::after
    box-sizing border-box

  .syp-btn
    display inline-flex
    align-items center
    justify-content center
    padding $syp-spacing-sm $syp-spacing-md
    border none
    border-radius $syp-radius-md
    font-size $syp-font-size-sm
    font-weight 500
    cursor pointer
    transition all 0.2s ease
    outline none

    &:hover
      opacity 0.9

    &:active
      opacity 0.8

    &.syp-btn-primary
      background-color $syp-primary
      color white

    &.syp-btn-secondary
      background-color $syp-bg-secondary
      color $syp-text-primary

    &.syp-btn-text
      background-color transparent
      color $syp-text-secondary

      &:hover
        background-color $syp-bg-secondary

  .syp-card
    background-color $syp-bg-primary
    border-radius $syp-radius-lg
    box-shadow $syp-shadow-sm
    border 1px solid $syp-border-secondary
    padding $syp-spacing-md
    transition box-shadow 0.2s ease

    &:hover
      box-shadow $syp-shadow-md

  .syp-input
    width 100%
    padding $syp-spacing-sm $syp-spacing-md
    border 1px solid $syp-border-primary
    border-radius $syp-radius-md
    font-size $syp-font-size-sm
    color $syp-text-primary
    background-color $syp-bg-primary
    transition border-color 0.2s ease

    &:focus
      outline none
      border-color $syp-primary

    &::placeholder
      color $syp-text-tertiary

  .syp-toggle
    position relative
    display inline-block
    width 44px
    height 24px

    input
      opacity 0
      width 0
      height 0

      &:checked + .syp-toggle-slider
        background-color $syp-primary

      &:checked + .syp-toggle-slider:before
        transform translateX(20px)

    .syp-toggle-slider
      position absolute
      cursor pointer
      top 0
      left 0
      right 0
      bottom 0
      background-color $syp-border-primary
      border-radius 24px
      transition 0.3s

      &:before
        position absolute
        content ""
        height 18px
        width 18px
        left 3px
        bottom 3px
        background-color white
        border-radius 50%
        transition 0.3s

  .syp-panel
    background linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 253, 0.98) 100%)
    border-radius $syp-radius-xl
    box-shadow $syp-shadow-lg
    border 1px solid rgba(222, 224, 227, 0.9)
    overflow hidden

  .syp-header
    display flex
    align-items center
    justify-content space-between
    padding $syp-spacing-md $syp-spacing-lg
    border-bottom 1px solid $syp-border-secondary

    .syp-header-title
      font-size $syp-font-size-lg
      font-weight 600
      color $syp-text-primary

  .syp-content
    padding $syp-spacing-lg
    overflow-y auto

  .syp-list
    list-style none
    margin 0
    padding 0

    .syp-list-item
      display flex
      align-items center
      padding $syp-spacing-md
      border-bottom 1px solid $syp-border-secondary
      cursor pointer
      transition background-color 0.2s ease

      &:hover
        background-color $syp-bg-secondary

      &:last-child
        border-bottom none

  .syp-empty
    display flex
    flex-direction column
    align-items center
    justify-content center
    padding $syp-spacing-xl
    color $syp-text-tertiary
    text-align center

    .syp-empty-icon
      font-size 48px
      margin-bottom $syp-spacing-md

    .syp-empty-text
      font-size $syp-font-size-md
      margin-bottom $syp-spacing-sm

    .syp-empty-subtext
      font-size $syp-font-size-sm

  .syp-shell
    display grid
    gap 0
    min-height 440px

    &.is-quick-publish
      grid-template-columns 176px minmax(0, 1fr)

    &.is-settings
      grid-template-columns 176px 196px minmax(0, 1fr) 248px

  .syp-shell__brand
    background linear-gradient(180deg, #79a8e6 0%, #4f84c8 42%, #315b93 100%)
    color white
    padding 18px
    display flex
    align-items stretch
    position relative

    &::after
      content ""
      position absolute
      inset 0
      background linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0) 38%)
      pointer-events none

  .syp-brand-card
    display flex
    flex-direction column
    justify-content space-between
    width 100%
    min-height 100%

  .syp-brand-chip
    display inline-flex
    align-items center
    width fit-content
    padding 5px 12px
    border 1px solid rgba(255, 255, 255, 0.28)
    border-radius 999px
    font-size $syp-font-size-xs
    letter-spacing 0.04em
    background rgba(255, 255, 255, 0.1)

  .syp-brand-title
    margin-top auto
    font-size 28px
    line-height 1.08
    font-weight 680
    letter-spacing -0.02em
    max-width 6ch

  .syp-brand-meta
    margin-top $syp-spacing-md
    font-size $syp-font-size-xs
    color rgba(255, 255, 255, 0.76)

  .syp-shell__nav
    padding $syp-spacing-lg
    background linear-gradient(180deg, #f7f9fc 0%, #eef2f6 100%)
    border-right 1px solid $syp-border-secondary

  .syp-shell__section-title
    margin-bottom $syp-spacing-md
    font-size $syp-font-size-xs
    color $syp-text-tertiary
    letter-spacing 0.08em
    text-transform uppercase

  .syp-shell__nav-item
    width 100%
    text-align left
    border none
    background transparent
    color $syp-text-secondary
    padding 12px 14px
    border-radius $syp-radius-lg
    margin-bottom $syp-spacing-sm
    cursor pointer
    transition all 0.2s ease

    &:hover
      background rgba(64, 128, 255, 0.08)
      color $syp-text-primary

    &.is-active
      background white
      color $syp-text-primary
      box-shadow $syp-shadow-sm

  .syp-shell__main
    padding $syp-spacing-xl
    background $syp-bg-primary
    min-width 0

  .syp-shell__detail
    padding $syp-spacing-xl
    background linear-gradient(180deg, #fbfcfd 0%, #f3f6f9 100%)
    border-left 1px solid $syp-border-secondary

  @media (max-width: 960px)
    .syp-shell
      &.is-quick-publish
        grid-template-columns 1fr

      &.is-settings
        grid-template-columns 1fr

    .syp-shell__nav,
    .syp-shell__detail
      border none

    .syp-brand-title
      max-width none
